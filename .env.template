# Production deployment URL (Reflex uses this to build correct API/websocket URLs)
DEPLOY_URL=https://materialized-enhancements.longevity-genie.info
REFLEX_API_URL=https://materialized-enhancements.longevity-genie.info
RESEND_API_KEY=re_xxxxxxx
# ARTEX Platform API integration (see src/materialized_enhancements/artex.py)
# ARTEX_API_URL: base URL for the platform API server (no trailing slash, no /v1).
# ARTEX_API_TOKEN: the ARTEX_PLATFORM_ADMIN_TOKEN value configured on the API server.
#   This is exchanged for a short-lived session token at publish time.
# ARTEX_DISPLAY_ID: venue display ID to push artwork to when the ARTEX button is clicked.
#   Overridden at runtime by ?display_id=<id> query parameter.
ARTEX_API_URL=http://127.0.0.1:8787
ARTEX_API_TOKEN=abcd
ARTEX_DISPLAY_ID=test-wall

# Kiosk inactivity redirect URL — the page the kiosk returns to when the idle
# timer expires. The timer is only active when ?redirect=<url> is in the page URL;
# that query param takes precedence over this env value.
ARTEX_IDLE_URL=https://artex.live/

# Dev-only: when MATERIALIZED_DEV_MODE=1 the idle timer and post-publish redirects
# go here instead. Supports {slug} substitution.
ARTEX_DEV_REDIRECT_URL=http://127.0.0.1:8787/public/projects/{slug}

# Public frontend base URL used in Share & Report links/QR codes.
# Example generated link:
# http://localhost:3000/materialize?report=1&name=QSBuZXcgaHVtYW4sIHRvIGJl&cats=59
PUBLIC_APP_URL=https://materialized-enhancements.longevity-genie.info

# Kiosk idle timer duration. The timer is rendered and active only when the
# page URL contains ?redirect=<url>. IDLE_WARNING_SECONDS controls how many
# seconds before the end the band turns red.
IDLE_TIMEOUT_SECONDS=60
IDLE_WARNING_SECONDS=5
