# ARTEX Platform API integration (see src/materialized_enhancements/artex.py)
# These match the variables used by ARTEX's run-new-project.ts sample.
ARTEX_API_URL=http://localhost:8080/v1
ARTEX_API_TOKEN=dev-token-12345678
ARTEX_INSTANCE_ID=default

# Where "Create ARTEX Project" sends the visitor after a successful create+run.
# {project_id} is substituted with the new project ID.
ARTEX_PROJECT_URL_TEMPLATE=https://artex.live/project/{project_id}

# Kiosk inactivity target — top band redirects here when the idle timer expires.
ARTEX_IDLE_URL=https://artex.live/

# Dev-only: when MATERIALIZED_DEV_MODE=1 (set by `uv run start --dev`), both the
# project-created redirect AND the idle timer go to this URL instead. Supports
# {project_id} substitution — the default below lands on the ARTEX API's GET
# endpoint for the just-created project so you can visually verify it exists.
ARTEX_DEV_REDIRECT_URL=http://localhost:8080/v1/projects/{project_id}

# Kiosk idle timer (prod only). Timeout seconds, and the last-N-seconds "red" window.
IDLE_TIMEOUT_SECONDS=60
IDLE_WARNING_SECONDS=5
